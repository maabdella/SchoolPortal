<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolPortal.GradeApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SchoolPortal.GradeApp.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
</head>
<body class="sp-body">
    <header class="sp-topbar">
        <nav class="navbar navbar-expand-sm navbar-light border-bottom">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-semibold" asp-controller="Grade" asp-action="Index">SchoolPortal Grades</a>
                <div class="navbar-nav">
                    <a class="nav-link" asp-controller="Grade" asp-action="Index">Grades</a>
                    <a class="nav-link" asp-controller="Grade" asp-action="Create">Add Grade</a>
                </div>
            </div>
        </nav>
    </header>

    <main class="sp-main">
        @RenderBody()
    </main>

    <footer class="sp-footer text-muted">
        <div class="container-fluid px-4 py-3">
            &copy; 2026 - SchoolPortal.GradeApp
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
