@model SchoolPortal.StudentApp.Models.Student

@{
    ViewData["Title"] = "Student Details";
    var initials = string.Concat(
        (Model.FirstName?.Length > 0 ? Model.FirstName[0].ToString() : ""),
        (Model.LastName?.Length  > 0 ? Model.LastName[0].ToString()  : "")
    );
    var daysSinceEnrollment = (DateTime.Today - Model.EnrollmentDate.Date).Days;
    var yearsEnrolled = Math.Floor(daysSinceEnrollment / 365.0);
}

<!-- ===== STYLES ===== -->
<partial name="_StudentLayout" />

<div class="sp-page" style="max-width:780px;">

    <!-- PAGE HEADER -->
    <div class="sp-page-header">
        <div class="sp-page-header__titles">
            <div class="sp-breadcrumb">
                <a href="/">Home</a>
                <span>›</span>
                <a asp-action="Index">Students</a>
                <span>›</span>
                @Model.FirstName @Model.LastName
            </div>
            <h1 class="sp-page-title">Student Details</h1>
        </div>
        <div class="sp-btn-group">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="sp-btn sp-btn--primary">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2"
                     viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 012.828 2.828L11.828 15.828a2 2 0 01-1.414.586H9v-2a2 2 0 01.586-1.414z"/>
                </svg>
                Edit Student
            </a>
            <a asp-action="Index" class="sp-btn sp-btn--outline">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"
                     viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Back to List
            </a>
        </div>
    </div>

    <!-- PROFILE CARD -->
    <div class="sp-card" style="margin-bottom:1.2rem;">
        <div class="sp-card__header">
            <div class="sp-card__header-icon">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
                     viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round"
                          d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <div class="sp-card__header-text">
                <h2>Student Profile</h2>
                <p>Full enrollment record and contact information</p>
            </div>
        </div>

        <div class="sp-card__body">

            <!-- HERO / PROFILE SUMMARY -->
            <div class="sp-student-hero">
                <span class="sp-avatar" style="width:64px;height:64px;font-size:1.35rem;">@initials</span>
                <div class="sp-student-hero__info">
                    <h3>@Model.FirstName @Model.LastName</h3>
                    <p>
                        <a href="mailto:@Model.Email" style="color:var(--sp-accent);text-decoration:none;">
                            @Model.Email
                        </a>
                        &nbsp;·&nbsp; ID #@Model.Id
                    </p>
                </div>
                <span class="sp-badge sp-badge--success" style="margin-left:auto;align-self:flex-start;">
                    Active
                </span>
            </div>

            <!-- STATS ROW -->
            <div class="sp-stats" style="padding-bottom:1.5rem;margin-bottom:1.5rem;border-bottom:1px solid var(--sp-border);">
                <div class="sp-stat">
                    <span class="sp-stat__val">@Model.EnrollmentDate.ToString("MMM yyyy")</span>
                    <span class="sp-stat__lbl">Enrolled Since</span>
                </div>
                <div class="sp-stat">
                    <span class="sp-stat__val">@daysSinceEnrollment</span>
                    <span class="sp-stat__lbl">Days Enrolled</span>
                </div>
                @if (yearsEnrolled >= 1)
                {
                    <div class="sp-stat">
                        <span class="sp-stat__val">@yearsEnrolled yr@(yearsEnrolled > 1 ? "s" : "")</span>
                        <span class="sp-stat__lbl">Years at School</span>
                    </div>
                }
            </div>

            <!-- SECTION: PERSONAL INFO -->
            <p style="font-size:.73rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
                      color:var(--sp-muted);margin:0 0 1rem;">Personal Information</p>

            <div class="sp-detail-grid" style="margin-bottom:1.5rem;">
                <div class="sp-detail-item">
                    <span class="sp-detail-label">First Name</span>
                    <span class="sp-detail-value">@Model.FirstName</span>
                </div>
                <div class="sp-detail-item">
                    <span class="sp-detail-label">Last Name</span>
                    <span class="sp-detail-value">@Model.LastName</span>
                </div>
                <div class="sp-detail-item">
                    <span class="sp-detail-label">Email Address</span>
                    <span class="sp-detail-value">
                        <a href="mailto:@Model.Email"
                           style="color:var(--sp-accent);text-decoration:none;font-weight:500;">
                            @Model.Email
                        </a>
                    </span>
                </div>
            </div>

            <hr class="sp-divider" />

            <!-- SECTION: ENROLLMENT INFO -->
            <p style="font-size:.73rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;
                      color:var(--sp-muted);margin:0 0 1rem;">Enrollment Information</p>

            <div class="sp-detail-grid">
                <div class="sp-detail-item">
                    <span class="sp-detail-label">Student ID</span>
                    <span class="sp-detail-value">#@Model.Id</span>
                </div>
                <div class="sp-detail-item">
                    <span class="sp-detail-label">Enrollment Date</span>
                    <span class="sp-detail-value">@Model.EnrollmentDate.ToString("dddd, MMMM dd, yyyy")</span>
                </div>
            </div>

        </div><!-- /.sp-card__body -->
    </div><!-- /.sp-card -->

    <!-- DANGER ZONE -->
    <div style="background:var(--sp-white);border:1px solid var(--sp-border);border-radius:var(--sp-radius);
                padding:1rem 1.4rem;display:flex;align-items:center;justify-content:space-between;
                gap:1rem;flex-wrap:wrap;box-shadow:var(--sp-shadow-sm);">
        <div>
            <div style="font-size:.82rem;font-weight:700;color:var(--sp-danger);margin-bottom:.15rem;">
                Danger Zone
            </div>
            <div style="font-size:.82rem;color:var(--sp-muted);">
                Permanently remove this student and all associated records.
            </div>
        </div>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="sp-btn sp-btn--danger sp-btn--sm">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"
                 viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M8 7V4a1 1 0 011-1h6a1 1 0 011 1v3"/>
            </svg>
            Delete Student
        </a>
    </div>

</div><!-- /.sp-page -->
