@model IEnumerable<SchoolPortal.StudentApp.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<!-- ===== STYLES ===== -->
<partial name="_StudentLayout" />

<div class="sp-page">

    <!-- PAGE HEADER -->
    <div class="sp-page-header">
        <div class="sp-page-header__titles">
            <div class="sp-breadcrumb">
                <a href="/">Home</a>
                <span>›</span>
                Students
            </div>
            <h1 class="sp-page-title">Student Directory</h1>
        </div>
        <div class="sp-btn-group">
            <a asp-action="Create" class="sp-btn sp-btn--primary">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2"
                     viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round"
                     d="M12 4v16m8-8H4"/></svg>
                Add New Student
            </a>
        </div>
    </div>

    <!-- STATS -->
    <div class="sp-stats">
        <div class="sp-stat">
            <span class="sp-stat__val">@Model.Count()</span>
            <span class="sp-stat__lbl">Total Students</span>
        </div>
        <div class="sp-stat">
            <span class="sp-stat__val">@Model.Count(s => s.EnrollmentDate >= DateTime.Today.AddMonths(-6))</span>
            <span class="sp-stat__lbl">Recent Enrollments</span>
        </div>
    </div>

    <!-- TABLE CARD -->
    <div class="sp-card">
        <div class="sp-card__header">
            <div class="sp-card__header-icon">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"
                     viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round"
                     d="M17 20h5v-2a4 4 0 00-5-3.87M9 20H4v-2a4 4 0 015-3.87m6-3a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            </div>
            <div class="sp-card__header-text">
                <h2>Enrolled Students</h2>
                <p>Manage student records, details, and enrollment status</p>
            </div>
        </div>

        <div class="sp-table-wrapper">
            <table class="sp-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Student</th>
                        <th>Email Address</th>
                        <th>Enrollment Date</th>
                        <th>Status</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6">
                                <div class="sp-table__empty">
                                    <svg width="48" height="48" fill="none" stroke="currentColor"
                                         stroke-width="1.2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round"
                                              d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                    <p>No students found. <a asp-action="Create" class="sp-btn sp-btn--primary sp-btn--sm" style="margin-left:.5rem;">Add the first student →</a></p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        int idx = 1;
                        @foreach (var student in Model)
                        {
                            var initials = string.Concat(
                                (student.FirstName?.Length > 0 ? student.FirstName[0].ToString() : ""),
                                (student.LastName?.Length  > 0 ? student.LastName[0].ToString()  : "")
                            );
                            <tr>
                                <td style="color:var(--sp-muted);font-size:.82rem;font-weight:600;">@idx</td>
                                <td>
                                    <div class="sp-name-cell">
                                        <span class="sp-avatar">@initials</span>
                                        <div>
                                            @student.FirstName @student.LastName
                                            <small>ID: @student.Id</small>
                                        </div>
                                    </div>
                                </td>
                                <td style="color:var(--sp-muted);">@student.Email</td>
                                <td>
                                    <span style="font-weight:500;">
                                        @student.EnrollmentDate.ToString("MMM dd, yyyy")
                                    </span>
                                </td>
                                <td>
                                    @if (student.EnrollmentDate >= DateTime.Today.AddMonths(-6))
                                    {
                                        <span class="sp-badge sp-badge--success">New</span>
                                    }
                                    else
                                    {
                                        <span class="sp-badge sp-badge--info">Active</span>
                                    }
                                </td>
                                <td>
                                    <div class="sp-actions" style="justify-content:flex-end;">
                                        <a asp-action="Details" asp-route-id="@student.Id"
                                           class="sp-btn sp-btn--ghost sp-btn--sm"
                                           title="View Details">
                                            <svg width="14" height="14" fill="none" stroke="currentColor"
                                                 stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                            </svg>
                                            Details
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@student.Id"
                                           class="sp-btn sp-btn--outline sp-btn--sm"
                                           title="Edit Student">
                                            <svg width="14" height="14" fill="none" stroke="currentColor"
                                                 stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 012.828 2.828L11.828 15.828a2 2 0 01-1.414.586H9v-2a2 2 0 01.586-1.414z"/>
                                            </svg>
                                            Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@student.Id"
                                           class="sp-btn sp-btn--danger sp-btn--sm"
                                           title="Delete Student">
                                            <svg width="14" height="14" fill="none" stroke="currentColor"
                                                 stroke-width="2" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M8 7V4a1 1 0 011-1h6a1 1 0 011 1v3"/>
                                            </svg>
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            idx++;
                        }
                    }
                </tbody>
            </table>
        </div><!-- /.sp-table-wrapper -->
    </div><!-- /.sp-card -->

</div><!-- /.sp-page -->
